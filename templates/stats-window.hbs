<div class="statistics-dice-shell">
    <nav class="tabs" data-group="primary-tabs">
        <a class="item" data-tab="stats"><i class="fas fa-chart-bar"></i> Статистика</a>
        <a class="item" data-tab="tops"><i class="fas fa-crown"></i> Топы</a>
        <a class="item" data-tab="records"><i class="fas fa-medal"></i> Рекорды</a>
        <a class="item" data-tab="achievements"><i class="fas fa-trophy"></i> {{#if enableEconomy}}Ачивки и магазин{{else}}Ачивки{{/if}}</a>
        {{#if enableAltar}}
        <a class="item" data-tab="altar" style="color: #d16ff1;"><i class="fas fa-fire"></i> Алтарь Удачи</a>
        {{/if}}
    </nav>

    {{#unless trackingEnabled}}
    <section class="tracking-paused-banner">
        <div class="tracking-paused-copy">
            <strong><i class="fas fa-pause-circle"></i> Учет статистики на паузе</strong>
            <span>Новые броски и ачивки сейчас не записываются. Включить учет можно в настройках модуля.</span>
        </div>
    </section>
    {{/unless}}

    <section class="content">
        <div class="tab" data-tab="stats">
            <section class="stats-hero">
                <div class="hero-copy">
                    <span class="hero-kicker">Savage Worlds · Statistics Dice</span>
                    <h2>Журнал удачи и хаоса</h2>
                    <p>Кто тащит, кто любит d6 и кто чаще всех поджигает кубы.</p>
                </div>
                <div class="hero-actions">
                    <div class="toggle-switch">
                        <span class="label {{#if (eq scope 'session')}}active{{/if}}" data-scope="session">Сессия</span>
                        <label class="switch">
                            <input type="checkbox" class="stats-scope-toggle" {{#if (eq scope 'allTime')}}checked{{/if}}>
                            <span class="slider round"></span>
                        </label>
                        <span class="label {{#if (eq scope 'allTime')}}active{{/if}}" data-scope="allTime">Все время</span>
                    </div>
                    {{#if isGM}}
                    <div class="gm-buttons">
                        <button class="reset-session"><i class="fas fa-hourglass-start"></i> Сессия</button>
                    </div>
                    {{/if}}
                </div>
            </section>

            <div class="players-list">
                {{#each players}}
                <article class="player-card" data-user-id="{{this.id}}">
                    <div class="player-header" data-collapsible="true">
                        <div class="player-name">
                            <span class="toggle-pill"><i class="toggle-icon fas fa-chevron-down"></i></span>
                            <div>
                                <h3>{{this.name}}</h3>
                                <div class="player-subline">
                                    {{#if this.isSelf}}<span>Это вы</span>{{else}}<span>Игрок мира</span>{{/if}}
                                    <span>{{this.displayStats.totalDieTypes}} типов кубов</span>
                                    <span>Средний результат: {{this.displayStats.overallAverage}}</span>
                                </div>
                            </div>
                        </div>
                        <div class="player-header-badges">
                            <span class="badge badge-luck {{this.displayStats.luck.cssClass}}">
                                <i class="fas fa-star"></i> {{this.displayStats.luck.tier}}
                            </span>
                        </div>
                        <div class="action-buttons">
                            <button class="share-chat" data-userid="{{this.id}}" title="Краткая сводка"><i class="fas fa-comment-alt"></i></button>
                            <button class="share-extended" data-userid="{{this.id}}" title="Подробная статистика"><i class="fas fa-file-alt"></i></button>
                            <button class="share-skills" data-userid="{{this.id}}" title="Топ навыков"><i class="fas fa-list"></i></button>
                        </div>
                    </div>

                    <div class="player-overview">
                        <div class="metric-grid">
                            <div class="metric-card"><span class="metric-label">Действий</span><strong class="metric-value">{{this.displayStats.totalActions}}</strong></div>
                            <div class="metric-card"><span class="metric-label">Кубов</span><strong class="metric-value">{{this.displayStats.totalDiceRolled}}</strong></div>
                            <div class="metric-card"><span class="metric-label">Подъемов</span><strong class="metric-value accent-success">{{this.displayStats.raises}}</strong></div>
                            <div class="metric-card"><span class="metric-label">Ачивок</span><strong class="metric-value" style="color:#dca04d;">{{this.achievementSummary.unlocked}}<span style="font-size:0.6em;color:rgba(255,255,255,0.4);">/{{this.achievementSummary.total}}</span></strong></div>
                            {{#if ../enableEconomy}}
                            <div class="metric-card"><span class="metric-label">LP</span><strong class="metric-value" style="color:#7ddf9c;">{{this.luckPoints}}</strong></div>
                            {{/if}}
                        </div>
                    </div>

                    <div class="player-details-container" style="display:none; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.05);">
                        <div class="dice-toggle-wrapper" style="margin-bottom: 16px; display: flex; justify-content: flex-end;">
                            <button class="toggle-dice-stats" data-userid="{{this.id}}" style="padding: 8px 16px; font-size: 0.8rem; background: rgba(255,255,255,0.1); color: #f4ebd6; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; cursor: pointer; transition: background 0.2s;">
                                <i class="fas fa-dice"></i> Показать статистику по кубам
                            </button>
                        </div>

                        <div class="detail-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px;">
                            <section class="detail-panel">
                                <div class="panel-header"><h4>Топ-5 навыков</h4><span>Самые частые проверки</span></div>
                                    <ul class="skill-heatmap">
                                        {{#each this.displayStats.skillUsage}}
                                        <li>
                                            <div class="skill-row"><span class="skill-name">{{this.name}}</span><span class="skill-count">{{this.count}} раз</span></div>
                                            <div class="skill-meta">Максимум: {{this.max}}</div>
                                        </li>
                                        {{else}}
                                        <li class="empty-state">Нет данных по навыкам.</li>
                                        {{/each}}
                                    </ul>
                                </section>

                                <section class="detail-panel">
                                    <div class="panel-header"><h4>Достижения и LP</h4><span>Интересные факты</span></div>
                                    <div class="benny-stat-grid">
                                        {{#each this.highlightStats}}
                                        <div class="benny-stat-card">
                                            <span class="benny-stat-label"><i class="{{this.icon}}"></i> {{this.label}}</span>
                                            <strong class="benny-stat-value">{{this.value}}</strong>
                                        </div>
                                        {{/each}}
                                    </div>
                                </section>

                                <section class="detail-panel">
                                    <div class="panel-header"><h4>Личные рекорды</h4><span>{{#if (eq ../scope 'session')}}Сессия{{else}}Все время{{/if}}</span></div>
                                    <div class="record-list">
                                        {{#each this.recordList}}
                                        <div class="record-list-item">
                                            <span class="record-list-title"><i class="{{this.icon}}"></i> {{this.title}}</span>
                                            <strong class="record-list-value">{{this.value}}</strong>
                                            <span class="record-list-label">{{this.label}}</span>
                                        </div>
                                        {{else}}
                                        <div class="empty-state record-empty">Пока рекордов нет.</div>
                                        {{/each}}
                                    </div>
                                </section>
                        </div>

                        <div class="dice-table-container" id="dice-table-{{this.id}}" style="display:none; margin-top: 16px;">
                            <section class="detail-panel">
                                <div class="panel-header"><h4>Статистика по кубам</h4><span>Распределение и средние значения</span></div>
                                <div class="table-wrap">
                                    <table class="dice-table">
                                        <thead>
                                            <tr>
                                                <th>Куб</th>
                                                <th>Бросков</th>
                                                <th>Среднее</th>
                                                <th>Удача</th>
                                                <th>Взрывов</th>
                                                <th>Распределение</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {{#each this.displayStats.dice}}
                                            <tr>
                                                <td class="die-type">{{this.type}}</td>
                                                <td>{{this.rolls}}</td>
                                                <td>{{this.average}}</td>
                                                <td class="{{this.luckCssClass}}">{{this.luckTier}}</td>
                                                <td>{{this.explosions}}</td>
                                                <td class="distribution-cell">
                                                    <div class="distribution-grid">
                                                        {{#each this.distributionEntries}}
                                                        <span class="distribution-chip" title="{{this.percent}}%">
                                                            <strong>{{this.result}}</strong>
                                                            <small>x{{this.quantity}}</small>
                                                        </span>
                                                        {{/each}}
                                                    </div>
                                                </td>
                                            </tr>
                                            {{else}}
                                            <tr><td colspan="6" class="empty-table">Нет данных по кубам.</td></tr>
                                            {{/each}}
                                        </tbody>
                                    </table>
                                </div>
                            </section>
                        </div>
                    </div>
                </article>
                {{/each}}
            </div>
        </div>

        <div class="tab" data-tab="tops">
            <section class="stats-hero achievements-hero">
                <div class="hero-copy">
                    <span class="hero-kicker">Leaderboards · Savage Worlds</span>
                    <h2>Топы по группе</h2>
                    <p>Отдельная витрина удачи, взрывов и критпровалов. Работает поверх текущей статистики без сброса данных.</p>
                </div>
                <div class="hero-actions">
                    <div class="toggle-switch">
                        <span class="label {{#if (eq scope 'session')}}active{{/if}}" data-scope="session">Сессия</span>
                        <label class="switch">
                            <input type="checkbox" class="stats-scope-toggle" {{#if (eq scope 'allTime')}}checked{{/if}}>
                            <span class="slider round"></span>
                        </label>
                        <span class="label {{#if (eq scope 'allTime')}}active{{/if}}" data-scope="allTime">Все время</span>
                    </div>
                    <button class="show-session-summary" {{#unless hasScopedSummary}}disabled{{/unless}}>
                        <i class="fas fa-film"></i> {{#if (eq scope 'session')}}Сводка сессии{{else}}Сводка за все время{{/if}}
                    </button>
                </div>
            </section>

            <div class="leaderboard-grid">
                {{#each topBoards}}
                {{#if this.hasEntries}}
                <section class="detail-panel leaderboard-panel {{this.accentClass}}">
                    <div class="panel-header">
                        <h4><i class="{{this.icon}}"></i> {{this.title}}</h4>
                        <span>{{this.subtitle}}</span>
                    </div>
                    <div class="leaderboard-highlight">
                        <div class="leaderboard-highlight-copy">
                            <span class="leaderboard-kicker">{{this.winnerLabel}}</span>
                            <strong>{{this.winner.name}}</strong>
                            <span>{{this.winner.secondary}}</span>
                        </div>
                        <div class="leaderboard-score {{this.winner.scoreClass}}">{{this.winner.scoreText}}</div>
                    </div>
                    <div class="leaderboard-list">
                        {{#each this.entries}}
                        <article class="leaderboard-item">
                            <span class="leaderboard-rank">#{{this.position}}</span>
                            <div class="leaderboard-player">
                                <strong>{{this.name}}</strong>
                                <span>{{this.secondary}}</span>
                            </div>
                            <span class="leaderboard-points {{this.scoreClass}}">{{this.scoreText}}</span>
                        </article>
                        {{/each}}
                    </div>
                </section>
                {{/if}}
                {{/each}}
            </div>
        </div>

        <div class="tab" data-tab="records">
            <section class="stats-hero achievements-hero">
                <div class="hero-copy">
                    <span class="hero-kicker">Record Board · Savage Worlds</span>
                    <h2>Лента рекордов</h2>
                    <p>Последние сильные броски, мировые рекорды и громкие личные вершины.</p>
                </div>
            </section>

            <div class="records-layout">
                <div class="records-main">
                    {{#if hasGlobalRecords}}
                    <section class="detail-panel global-records-panel" style="margin-bottom: 16px;">
                        <div class="panel-header" style="background: linear-gradient(90deg, rgba(255, 203, 125, 0.1), transparent);">
                            <h4><i class="fas fa-globe" style="color:#ffcb7d;"></i> Абсолютные Рекорды Мира</h4>
                            <span>Исторические максимумы группы</span>
                        </div>
                        <div class="global-records-grid">
                            {{#each globalRecords}}
                            <div class="global-record-card">
                                <i class="{{this.icon}}"></i>
                                <div class="global-record-info">
                                    <span class="global-record-label">{{this.label}}</span>
                                    <strong class="global-record-value">{{this.value}}</strong>
                                    <span class="global-record-name">{{this.name}}</span>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                    </section>
                    {{/if}}

                    <section class="detail-panel">
                        <div class="panel-header"><h4><i class="fas fa-user-astronaut"></i> Аллея Славы</h4><span>Личные достижения игроков</span></div>
                        <div class="personal-records-grid" style="padding: 14px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px;">
                            {{#each allPlayers}}
                            {{#if this.recordList.length}}
                            <div class="personal-record-player" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 12px;">
                                <strong style="display:block; margin-bottom:8px; color: var(--sd-text);">{{this.name}}</strong>
                                <div style="display:grid; gap:6px;">
                                    {{#each this.recordList}}
                                    <div style="display:flex; justify-content: space-between; font-size: 0.8rem;">
                                        <span style="color:var(--sd-muted);"><i class="{{this.icon}}"></i> {{this.title}}</span>
                                        <strong style="color:var(--sd-accent-strong);">{{this.value}}</strong>
                                    </div>
                                    {{/each}}
                                </div>
                            </div>
                            {{/if}}
                            {{/each}}
                        </div>
                    </section>
                </div>

                <div class="records-sidebar">
                    {{#if hasRecordFeed}}
                    <section class="record-feed-panel record-feed-tab">
                        <div class="panel-header"><h4>Лента событий</h4><span>Автоматически обновляется</span></div>
                        <div class="record-feed-list">
                            {{#each recordFeed}}
                            <article class="record-feed-item {{this.levelClass}}">
                                <div class="record-feed-icon"><i class="{{this.icon}}"></i></div>
                                <div class="record-feed-content">
                                    <div class="record-feed-title"><strong>{{this.userName}}</strong><span>{{this.title}}</span></div>
                                    <div class="record-feed-meta">
                                        <span class="record-feed-value">{{this.value}}</span>
                                        <span>{{this.label}}</span>
                                        <span>{{this.levelText}}</span>
                                        <span>{{this.timeText}}</span>
                                    </div>
                                </div>
                            </article>
                            {{/each}}
                        </div>
                    </section>
                    {{else}}
                    <section class="record-feed-panel record-feed-tab">
                        <div class="panel-header"><h4>Лента событий</h4><span>Пока пусто</span></div>
                        <div class="record-feed-empty">Сделайте несколько бросков, и здесь появятся новые рекорды.</div>
                    </section>
                    {{/if}}
                </div>
            </div>
        </div>

        <div class="tab" data-tab="achievements">
            <section class="stats-hero achievements-hero">
                <div class="hero-copy">
                    <span class="hero-kicker">Trophy Board</span>
                    <h2>Коллекция достижений</h2>
                    <p>Витрина ачивок{{#if enableEconomy}}, LP и обмена удачи на бенни{{/if}}.</p>
                </div>
            </section>

            <div class="players-list achievements-list">
                {{#each players}}
                <article class="player-card achievement-section">
                    <div class="player-header no-hover achievement-header">
                        <div>
                            <h3>{{this.name}}</h3>
                            <div class="player-subline">
                                <span>{{this.achievementSummary.unlocked}} / {{this.achievementSummary.total}} открыто</span>
                                <span>{{this.achievementSummary.completion}}% коллекции</span>
                                <span>{{this.achievementSummary.legendary}} легендарных</span>
                            </div>
                        </div>

                        {{#if ../enableEconomy}}
                        <div class="lp-counter">
                            <div class="lp-bank">
                                <span class="lp-label">Luck Points</span>
                                <span class="lp-value">{{this.luckPoints}} LP</span>
                            </div>
                            <button class="buy-benny" data-userid="{{this.id}}" {{#if (lt this.luckPoints 100)}}disabled{{/if}} title="Купить фишку (100 LP)">
                                <i class="fas fa-shopping-cart"></i> Купить
                            </button>
                            <button class="gift-benny" data-userid="{{this.id}}" {{#if (lt this.luckPoints 200)}}disabled{{/if}} title="Подарить фишку (200 LP)">
                                <i class="fas fa-gift"></i> Подарить
                            </button>
                        </div>
                        {{/if}}
                    </div>

                    <div class="progress-trio" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px; padding: 0 16px;">
                        <div class="progress-card">
                            <div class="progress-meta"><span>Ачивки</span><strong>{{this.achievementSummary.unlocked}} / {{this.achievementSummary.total}}</strong></div>
                            <div class="lp-progress-bar" style="background: rgba(255,255,255,0.05); border-radius: 999px; height: 6px; overflow: hidden; margin-top: 6px;">
                                <div class="lp-progress-fill" style="width: {{this.achievementSummary.completion}}%; background: linear-gradient(90deg, #f1c978, #ce8f40); height: 100%;"></div>
                            </div>
                        </div>
                        {{#if ../enableEconomy}}
                        <div class="progress-card">
                            <div class="progress-meta"><span>Покупка фишки</span><strong>{{this.economy.nextBuyText}}</strong></div>
                            <div class="lp-progress-bar"><div class="lp-progress-fill" style="width: {{this.economy.buyProgress}}%;"></div></div>
                        </div>
                        <div class="progress-card">
                            <div class="progress-meta"><span>Подарок фишки</span><strong>{{this.economy.nextGiftText}}</strong></div>
                            <div class="lp-progress-bar secondary"><div class="lp-progress-fill" style="width: {{this.economy.giftProgress}}%;"></div></div>
                        </div>
                        {{/if}}
                    </div>

                    <div class="achievements-grid">
                        {{#each this.achievements}}
                        <div class="achievement-card {{this.cssClass}}" title="{{this.description}}">
                            <div class="ach-icon">
                                {{#if this.isUnlocked}}<i class="fas fa-trophy"></i>{{else}}<i class="fas fa-lock"></i>{{/if}}
                            </div>
                            <div class="ach-info">
                                <div class="ach-topline">
                                    <div class="ach-name">{{this.name}}</div>
                                    <span class="ach-rarity">{{this.rarity}}</span>
                                </div>
                                <div class="ach-description">{{this.description}}</div>
                                <div class="ach-footer">
                                    {{#if ../../enableEconomy}}
                                    <div class="ach-reward">+{{this.lp}} LP</div>
                                    {{/if}}
                                    {{#if this.isUnlocked}}
                                        {{#if (gt this.count 1)}}<div class="ach-count">x{{this.count}}</div>{{/if}}
                                    {{else}}
                                    <div class="ach-status">Locked</div>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </article>
                {{/each}}
            </div>
        </div>
        <div class="tab" data-tab="altar">
            {{#if enableAltar}}
            <section class="stats-hero altar-hero">
                <div class="hero-copy">
                    <span class="hero-kicker">Altar of Fortune</span>
                    <h2>{{altar.title}}</h2>
                    <p>Совместный вклад ради великой цели.</p>
                </div>
                {{#if isGM}}
                <div class="hero-actions">
                    <button class="altar-reset" style="background: rgba(255,0,0,0.1); color: #ff7676; border: 1px solid rgba(255,0,0,0.2);"><i class="fas fa-skull"></i> Очистить Алтарь</button>
                </div>
                {{/if}}
            </section>

            <div class="altar-container">
                <div class="altar-left-panel">
                    <div class="altar-visual">
                        <div class="altar-flame {{#if altar.isFull}}full{{/if}}">
                            {{#if altar.image}}
                            <img src="{{altar.image}}" alt="{{altar.title}}" style="display: block; margin: 0 auto; max-width: 210px; max-height: 210px; width: auto; height: auto; object-fit: contain; border: none; background: transparent; box-shadow: none;">
                            {{else}}
                            <i class="fas fa-fire-alt"></i>
                            {{/if}}
                        </div>
                        <div class="altar-status">
                            <h3>{{#if altar.isFull}}Чаша полна!{{else}}{{altar.title}}{{/if}}</h3>
                            <p>{{#if altar.isFull}}{{altar.rewardDesc}}{{else}}{{altar.description}}{{/if}}</p>
                        </div>
                    </div>

                    <div class="altar-progress-container">
                        <div class="altar-progress-text"><span>Пожертвовано:</span><strong>{{altar.lp}} / {{altar.goal}} LP</strong></div>
                        <div class="altar-progress-bar">
                            <div class="altar-progress-fill" style="width: {{altar.progressPercent}}%;"></div>
                        </div>
                    </div>
                </div>

                <div class="altar-right-panel">
                    <div class="altar-user-header">
                        <span><i class="fas fa-wallet" style="margin-right: 8px; color: #7ddf9c;"></i> Ваши очки удачи</span>
                        <strong>{{currentUserLP}} LP</strong>
                    </div>

                    <div class="altar-actions">
                        <button class="altar-donate" data-amount="10" {{#if (lt currentUserLP 10)}}disabled{{/if}}><i class="fas fa-coins"></i> <span>10 LP</span></button>
                        <button class="altar-donate" data-amount="50" {{#if (lt currentUserLP 50)}}disabled{{/if}}><i class="fas fa-gem"></i> <span>50 LP</span></button>
                        <button class="altar-donate" data-amount="100" style="color: #ffd700; border-color: rgba(255,215,0,0.3);" {{#if (lt currentUserLP 100)}}disabled{{/if}}><i class="fas fa-crown"></i> <span>100 LP</span></button>
                    </div>

                    {{#if altar.topContributors.length}}
                    <div class="altar-stats">
                        <h4>Щедрые Подношения</h4>
                        <div class="altar-contributors">
                            {{#each altar.topContributors}}
                            <div class="altar-contributor">
                                <span class="contributor-name">{{this.name}}</span>
                                <span class="contributor-amount">{{this.amount}} LP</span>
                            </div>
                            {{/each}}
                        </div>
                    </div>
                    {{/if}}
                </div>
            </div>
            {{else}}
            <div class="empty-state">Алтарь Удачи отключен в настройках.</div>
            {{/if}}
        </div>
    </section>
</div>
