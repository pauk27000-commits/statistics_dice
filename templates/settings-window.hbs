<form class="statistics-settings-shell">
    <section class="detail-panel settings-panel">
        <div class="panel-header">
            <h4>Учет статистики</h4>
            <span>Можно временно поставить модуль на паузу, чтобы тестовые броски не портили историю</span>
        </div>

        <label class="settings-user-row settings-toggle-row">
            <span class="settings-user-copy">
                <strong>Учитывать новые броски</strong>
                <small>Если выключить, модуль перестанет записывать статистику и выдавать ачивки до повторного включения</small>
            </span>
            <input type="checkbox" name="trackingEnabled" {{#if trackingEnabled}}checked{{/if}}>
        </label>

        <label class="settings-user-row settings-toggle-row">
            <span class="settings-user-copy">
                <strong>Экономика LP и Бенни</strong>
                <small>Включает счетчик LP, ачивки и возможность покупки фишек</small>
            </span>
            <input type="checkbox" name="enableEconomy" {{#if enableEconomy}}checked{{/if}}>
        </label>

        <label class="settings-user-row settings-toggle-row">
            <span class="settings-user-copy">
                <strong>Алтарь Удачи</strong>
                <small>Включает глобальный котел для пожертвований (требует включенной экономики)</small>
            </span>
            <input type="checkbox" name="enableAltar" {{#if enableAltar}}checked{{/if}}>
        </label>

        {{#if enableAltar}}
        <div class="altar-customization" style="margin-top: 10px; padding: 12px; background: rgba(0,0,0,0.15); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            <h5 style="margin: 0 0 12px 0; color: #d16ff1; font-size: 0.9rem;"><i class="fas fa-paint-brush"></i> Кастомизация Алтаря</h5>
            
            <label class="settings-user-row" style="display: flex; flex-direction: column; gap: 4px; align-items: flex-start; margin-bottom: 10px;">
                <span class="settings-user-copy" style="flex: none; width: 100%;"><strong>Название Алтаря</strong></span>
                <input type="text" name="altarTitle" value="{{altarTitle}}" style="width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f4ebd6; padding: 4px 8px; border-radius: 4px;">
            </label>

            <label class="settings-user-row" style="display: flex; flex-direction: column; gap: 4px; align-items: flex-start; margin-bottom: 10px;">
                <span class="settings-user-copy" style="flex: none; width: 100%;"><strong>Цель (LP)</strong></span>
                <input type="number" name="altarGoal" value="{{altarGoal}}" style="width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f4ebd6; padding: 4px 8px; border-radius: 4px;">
            </label>

            <label class="settings-user-row" style="display: flex; flex-direction: column; gap: 4px; align-items: flex-start; margin-bottom: 10px;">
                <span class="settings-user-copy" style="flex: none; width: 100%;"><strong>Изображение (путь или URL)</strong><small>Оставьте пустым для стандартного огонька</small></span>
                <div style="display: flex; gap: 5px; width: 100%;">
                    <input type="text" name="altarImage" value="{{altarImage}}" placeholder="Например: modules/statistics_dice/img/my_altar.webp" style="flex: 1; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f4ebd6; padding: 4px 8px; border-radius: 4px;">
                    {{filePicker target="altarImage" type="image"}}
                </div>
            </label>

            <label class="settings-user-row" style="display: flex; flex-direction: column; gap: 4px; align-items: flex-start; margin-bottom: 10px;">
                <span class="settings-user-copy" style="flex: none; width: 100%;"><strong>Описание (в процессе сбора)</strong></span>
                <textarea name="altarDescription" style="width: 100%; height: 60px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f4ebd6; padding: 6px 8px; border-radius: 4px; resize: vertical; font-family: inherit;">{{altarDescription}}</textarea>
            </label>

            <label class="settings-user-row" style="display: flex; flex-direction: column; gap: 4px; align-items: flex-start;">
                <span class="settings-user-copy" style="flex: none; width: 100%;"><strong>Текст (когда цель достигнута)</strong></span>
                <textarea name="altarRewardDesc" style="width: 100%; height: 60px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: #f4ebd6; padding: 6px 8px; border-radius: 4px; resize: vertical; font-family: inherit;">{{altarRewardDesc}}</textarea>
            </label>

            <div style="display: flex; justify-content: flex-end; margin-top: 12px;">
                <button type="button" class="altar-reset-defaults" style="flex: none; width: auto; padding: 4px 10px; font-size: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);"><i class="fas fa-undo"></i> Сбросить Алтарь к базовым</button>
            </div>
        </div>
        {{/if}}

        <div class="settings-actions">
            <button type="submit"><i class="fas fa-save"></i> Сохранить настройки</button>
        </div>
    </section>

    <section class="detail-panel settings-panel">
        <div class="panel-header">
            <h4>Видимость в статистике</h4>
            <span>Скрытые игроки пропадают из всех витрин модуля, но их данные сохраняются</span>
        </div>

        <div class="settings-users">
            {{#each users}}
            <label class="settings-user-row">
                <span class="settings-user-copy">
                    <strong>{{this.userName}}</strong>
                    {{#if this.characterName}}
                    <small>Персонаж: {{this.characterName}}</small>
                    {{else}}
                    <small>Персонаж не назначен</small>
                    {{/if}}
                </span>
                <input type="checkbox" name="hiddenUsers.{{this.id}}" {{#if this.isHidden}}checked{{/if}}>
            </label>
            {{/each}}
        </div>

        {{#if hasStaleHiddenUsers}}
        <div class="settings-stale-note">
            <strong>Устаревшие скрытые записи</strong>
            <div class="settings-stale-list">
                {{#each staleHiddenUsers}}
                <span class="settings-stale-chip">{{this.id}}</span>
                {{/each}}
            </div>
        </div>
        {{/if}}

        <div class="settings-actions">
            <button type="submit"><i class="fas fa-save"></i> Сохранить видимость</button>
        </div>
    </section>

    {{#if hasOrphans}}
    <section class="detail-panel settings-panel">
        <div class="panel-header">
            <h4>Отвязанная статистика</h4>
            <span>Статистика удаленных профилей. Ее можно перепривязать к существующим игрокам.</span>
        </div>
        <div class="settings-users">
            {{#each orphans}}
            <div class="settings-user-row">
                <span class="settings-user-copy">
                    <strong>{{this.originalName}}</strong>
                    <small>ID: {{this.id}}</small>
                </span>
                <div style="display: flex; gap: 10px; align-items: center;">
                    <select name="reassign-{{this.id}}">
                        <option value="">Выберите игрока...</option>
                        {{#each ../users}}
                        <option value="{{this.id}}">{{this.userName}}</option>
                        {{/each}}
                    </select>
                    <button type="button" class="reassign-orphan" data-orphan-id="{{this.id}}"><i class="fas fa-link"></i> Привязать</button>
                </div>
            </div>
            {{/each}}
        </div>
    </section>
    {{/if}}

    <section class="detail-panel settings-panel">
        <div class="panel-header">
            <h4>Импорт / экспорт</h4>
            <span>Copy-paste формат совместим с текущими JSON-бэкапами</span>
        </div>

        <div class="settings-copy-grid">
            <div class="settings-copy-block">
                <label class="settings-textarea-label" for="statistics-export-text">Экспорт</label>
                <textarea id="statistics-export-text" name="export-text" readonly>{{exportText}}</textarea>
                <div class="settings-actions">
                    <button type="button" class="copy-export"><i class="fas fa-copy"></i> Скопировать</button>
                </div>
            </div>

            <div class="settings-copy-block">
                <label class="settings-textarea-label" for="statistics-import-text">Импорт</label>
                <textarea id="statistics-import-text" name="import-text" placeholder="Вставьте сюда JSON статистики"></textarea>
                <div class="settings-actions">
                    <button type="button" class="import-replace"><i class="fas fa-file-import"></i> Заменить</button>
                    <button type="button" class="import-merge"><i class="fas fa-layer-group"></i> Объединить</button>
                </div>
            </div>
        </div>
    </section>

    <section class="detail-panel settings-panel danger-zone">
        <div class="panel-header">
            <h4>Опасные действия</h4>
            <span>Используйте только если действительно хотите очистить накопленную статистику</span>
        </div>

        <div class="danger-copy">
            <strong>Полный сброс статистики</strong>
            <p>Удаляет всю накопленную статистику мира. Настройки скрытия игроков останутся.</p>
        </div>
        <div class="settings-actions">
            <button type="button" class="clear-all-stats"><i class="fas fa-trash"></i> Полный сброс</button>
        </div>
    </section>
</form>